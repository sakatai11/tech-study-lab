{
  "name": "@tsl/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./type": "./src/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "wrangler deploy --dry-run --outdir dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tech-study-lab --local",
    "content:sync": "tsx scripts/sync-content.ts"
  },
  "dependencies": {
    "@tsl/shared": "workspace:*",
    "@hono/zod-validator": "0.4.2",
    "drizzle-orm": "0.38.3",
    "hono": "4.6.16",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250109.0",
    "drizzle-kit": "0.30.1",
    "gray-matter": "4.0.3",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "wrangler": "3.99.0"
  }
}
