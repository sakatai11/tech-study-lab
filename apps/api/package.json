{
  "name": "@tsl/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./type": "./src/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --project tsconfig.json && tsc --project tsconfig.scripts.json",
    "test": "vitest run --exclude src/core-endpoints.integration.test.ts && vitest run --config vitest.workers.config.ts src/core-endpoints.integration.test.ts",
    "build": "wrangler deploy --dry-run --outdir dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tech-study-lab --local",
    "content:sync": "tsx scripts/sync-content.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "0.4.2",
    "@tsl/shared": "workspace:*",
    "drizzle-orm": "0.38.3",
    "hono": "4.6.16",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "4.20260621.1",
    "@types/node": "22.10.5",
    "drizzle-kit": "0.30.1",
    "gray-matter": "4.0.3",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "wrangler": "4.103.0"
  }
}
