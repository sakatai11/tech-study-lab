    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@types/node": "22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "5.7.3",
    "wrangler": "4.103.0"
  }
}
