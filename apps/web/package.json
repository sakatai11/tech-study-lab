{
  "name": "@tsl/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "content:generate": "tsx scripts/generate-content.ts",
    "content:check": "tsx scripts/generate-content.ts --check",
    "prebuild": "pnpm content:generate",
    "build": "next build",
    "start": "next start",
    "preview": "pnpm content:generate && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm content:generate && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tsl/shared": "workspace:*",
    "clsx": "2.1.1",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "server-only": "0.0.1",
    "tailwind-merge": "2.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@types/node": "22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "gray-matter": "4.0.3",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "wrangler": "4.103.0"
  }
}
