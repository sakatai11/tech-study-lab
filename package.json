{
  "name": "tech-study-lab",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @tsl/api --filter @tsl/web dev",
    "dev:web": "pnpm --filter @tsl/web dev",
    "dev:api": "pnpm --filter @tsl/api dev",
    "content:sync": "pnpm --filter @tsl/api content:sync"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.7.3"
  }
}
